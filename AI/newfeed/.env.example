# --- Fanpage Source ---
PAGE_ID=your_page_id_here
PAGE_ACCESS_TOKEN=your_page_access_token_here

# --- Target Groups ---
# Danh sách ID Group cách nhau bởi dấu phẩy
GROUP_IDS=group_id_1,group_id_2,group_id_3

# --- Bot Control ---
POSTS_PER_DAY=20
DELAY_BETWEEN_POSTS=15
START_TIME=08:00
END_TIME=22:00

# --- System ---
USER_DATA_DIR=browser_data/user_profile
HISTORY_FILE=data/history.json
