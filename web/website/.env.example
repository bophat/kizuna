# =============================================================================
# KIZUNA Website — biến môi trường cho Vercel (và dev local)
# =============================================================================
# 1. Copy file này:  cp .env.example .env.local
# 2. Điền giá trị thật vào .env.local (không commit .env.local)
# 3. Trên Vercel: Project Settings → Environment Variables → thêm từng biến VITE_*
# 4. Vercel: Root Directory = web/website  |  Framework = Vite
# =============================================================================

# --- Bắt buộc (production) ---
# Django trên Render (có /api ở cuối)
VITE_API_BASE_URL=https://kizuna-api.onrender.com/api

# URL gốc backend — ảnh /media (KHÔNG có /api)
VITE_MEDIA_BASE_URL=https://kizuna-api.onrender.com

# URL website sau deploy (tuỳ chọn)
VITE_APP_URL=https://your-website.vercel.app

# --- Concierge / Live chat (tuỳ chọn) ---
# Service chat (port 8080 khi dev). Để trống nếu chưa deploy chatbot
VITE_CHAT_API_BASE_URL=https://your-chatbot.example.com/api

# --- AI Concierge (tuỳ chọn) ---
# Lấy tại https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# --- Dev local (mặc định nếu không set) ---
# VITE_API_BASE_URL=http://127.0.0.1:8000/api
# VITE_MEDIA_BASE_URL=http://127.0.0.1:8000
# VITE_CHAT_API_BASE_URL=http://localhost:8080/api
