# =============================================================================
# KIZUNA Backend (Django) — Render.com
# =============================================================================
# Render Dashboard → Web Service → Environment → Add từng biến
# Build Command:  ./build.sh   (hoặc lệnh trong render.yaml)
# Start Command:   gunicorn core.wsgi:application --bind 0.0.0.0:$PORT
# =============================================================================

# --- Bắt buộc ---
DJANGO_SECRET_KEY=change-me-to-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=kizuna-api.onrender.com,localhost,127.0.0.1

# Postgres (Render tự inject khi link database)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# CORS: URL Vercel (không dấu / cuối), phân tách bằng dấu phẩy
CORS_ALLOWED_ORIGINS=https://your-website.vercel.app,https://your-admin.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-website.vercel.app,https://your-admin.vercel.app,https://kizuna-api.onrender.com

# --- Tuỳ chọn ---
MEDIA_ROOT=/var/data/media
EXCHANGE_RATE_CACHE_SECONDS=3600
SECURE_SSL_REDIRECT=True

# --- AI / Chatbot bridge ---
CHATBOT_INTERNAL_TOKEN=change-me-shared-secret-with-flask
CHATBOT_SERVICE_URL=http://127.0.0.1:8080

# --- Dev local (không set DATABASE_URL → dùng SQLite) ---
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=*
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
