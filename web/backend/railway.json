{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildEnvironment": "V3"
  },
  "deploy": {
    "startCommand": "python manage.py migrate && gunicorn core.wsgi:application --bind 0.0.0.0:$PORT --workers 2",
    "restartPolicyType": "ON_FAILURE"
  }
}
