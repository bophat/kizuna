# =============================================================================
# KIZUNA Admin — Vercel (frontend)
# =============================================================================
# cp .env.example .env.local
# Vercel: Root Directory = web/admin  |  Framework = Vite
# =============================================================================

# Render Django API (có /api)
VITE_API_BASE_URL=https://kizuna-api.onrender.com/api

# Backend gốc — ảnh /media (KHÔNG /api)
VITE_MEDIA_BASE_URL=https://kizuna-api.onrender.com

# URL admin sau deploy
VITE_APP_URL=https://your-admin.vercel.app

# Chatbot: admin chat/SSE đi qua Django proxy (/api/admin/chat/*), không cần VITE_CHAT_API_BASE_URL

# --- Dev local ---
# VITE_API_BASE_URL=http://127.0.0.1:8000/api
# VITE_MEDIA_BASE_URL=http://127.0.0.1:8000
# VITE_CHAT_API_BASE_URL=  # deprecated — admin dùng Django proxy
